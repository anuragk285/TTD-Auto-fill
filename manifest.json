{
  "name": "ttd-auto-fill",
  "description": "Auto-fills pilgrim details form in TTD online booking flow",
  "version": "1.0",
  "manifest_version": 3,
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": ["https://ttdevasthanams.ap.gov.in/*"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "TTD Form Filler"
  }
}
